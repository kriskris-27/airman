# =============================================================================
# skynet-ops-audit-service – environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed.
# =============================================================================

# Flask / server
PORT=5000
APP_ENV=development          # development | staging | production

# Logging
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Storage
STORE_BACKEND=sqlite         # sqlite (only backend currently supported)
SQLITE_PATH=./data/events.db # path to the SQLite database file

# Service identity
SERVICE_NAME=skynet-ops-audit-service
